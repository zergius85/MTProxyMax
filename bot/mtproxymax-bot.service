[Unit]
Description=MTProxyMax Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mtproxymax/bot
Environment="PATH=/opt/mtproxymax/bot/venv/bin:/usr/bin:/bin"
ExecStart=/opt/mtproxymax/bot/venv/bin/python /opt/mtproxymax/bot/bot.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
